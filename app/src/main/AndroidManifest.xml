<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Whisperboy is SAF-only — audiobooks live in folders the user explicitly opts into via
      ACTION_OPEN_DOCUMENT_TREE. No READ_MEDIA_AUDIO, no READ_EXTERNAL_STORAGE.
      See CLAUDE.md "Why SAF (not MediaStore)" for the rationale.
    -->
    <!--
      INTERNET — used exclusively by cover-art Phase B's user-initiated DuckDuckGo image
      search (see docs/plans/cover-art.md). No automated network round-trips happen
      anywhere else in the app.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".WhisperboyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:windowSoftInputMode="adjustResize"
        android:theme="@style/Theme.Whisperboy">
        <activity
            android:name=".WhisperboyActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Foreground audio service. Both action filters are declared because Media3's
          discovery mechanism varies by client surface (MediaLibraryService for Auto / Wear-OS
          browse, MediaSessionService for direct controllers).
        -->
        <service
            android:name=".playback.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaLibraryService" />
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!--
          Debug smoke entry point — accepts a `path` extra and asks ExoPlayer to load it.
          Logs STATE_* to logcat under the "whisperboy.smoke" tag for scripts/smoke-test.sh.
          Will move to a debug-variant sourceset once Phase O introduces signing + variants.
        -->
        <receiver
            android:name=".playback.SmokePlayReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.eight87.whisperboy.action.SMOKE_PLAY" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
