<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Application theme. The system's cold-start splash is fine: Android 12+
      drops the round launcher icon into its circular splash slot, which
      matches our circular launcher artwork. windowBackground is set to the
      launcher background colour so the splash window doesn't flash white.
    -->
    <style name="Theme.Whisperboy" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/launcher_background</item>
    </style>
</resources>
