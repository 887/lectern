<?xml version="1.0" encoding="utf-8"?>
<!--
  whisperboy — canonical English string table. Source of truth for all locales.

  See docs/plans/translations.md for the per-locale workflow.

  Naming scheme: <surface>_<role> (lowercase snake). Surfaces:
    library_      cover grid, filter chips, sort menu, search, long-press sheet
    player_       transport, scrubber timestamps, top app bar, book/chapter title
    chapter_      chapter list bottom sheet, current-chapter indicator
    bookmark_     bookmark list, add/rename/delete, "set by sleep timer" badge
    sleep_        sleep timer sheet, fade-out, shake-to-resume
    folder_       SAF picker bridge, four FolderType labels + descriptions
    onboarding_   welcome, permissions rationale, picker explainer, first-scan
    settings_     every settings sub-page (Playback / Sleep / Library / Theme / About)
    widget_       home-screen widget labels + content descriptions
    auto_         Android Auto custom command labels
    permission_   POST_NOTIFICATIONS rationale
    dialog_       generic dialog buttons (Cancel / OK / Delete)
    error_        error messages
    cd_           content descriptions (transport buttons, cover art alt text)
-->
<resources xmlns:tools="http://schemas.android.com/tools" tools:locale="en">
    <string name="app_name">Whisperboy</string>

    <!-- folder_ — SAF picker bridge + the four FolderType labels (Phase C) -->
    <string name="folder_picker_empty_title">No audiobook folders yet</string>
    <string name="folder_picker_empty_subtitle">Tap below to pick the folder where your audiobooks live. Whisperboy will only see what you point it at.</string>
    <string name="folder_picker_cta">Pick an audiobook folder</string>
    <string name="folder_picker_add_another">Add another folder</string>

    <string name="folder_type_dialog_title">How is this folder organized?</string>
    <string name="folder_type_singlefile_title">Single file</string>
    <string name="folder_type_singlefile_subtitle">One audio file is one book.</string>
    <string name="folder_type_singlefolder_title">Single folder</string>
    <string name="folder_type_singlefolder_subtitle">One folder of audio files is one book; chapters are the files in alphabetical order.</string>
    <string name="folder_type_root_title">Root</string>
    <string name="folder_type_root_subtitle">Each subfolder inside is a separate book.</string>
    <string name="folder_type_author_title">Author</string>
    <string name="folder_type_author_subtitle">First level is the author, second level is the book.</string>

    <string name="folder_remove_action">Remove</string>
    <string name="folder_section_title">Audiobook folders</string>
    <string name="folder_rescan_action">Rescan now</string>
    <string name="folder_rescan_state_running">Scanning your library…</string>
    <string name="folder_rescan_state_failed">Scan failed — tap to retry</string>

    <!-- dialog_ — generic dialog buttons -->
    <string name="dialog_cancel">Cancel</string>

    <plurals name="folder_count">
        <item quantity="one">%1$d audiobook folder configured</item>
        <item quantity="other">%1$d audiobook folders configured</item>
    </plurals>
</resources>
